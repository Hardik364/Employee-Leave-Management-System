# ============================================================
#  Employee Leave Management System — Environment Variables
#  Copy this file to backend/.env and adjust values as needed.
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Supported dialects: sqlite (default, zero-config) | postgres
DB_DIALECT=sqlite
# For sqlite, this is the file path (relative to backend/)
DB_STORAGE=./data/leave_management.sqlite

# For postgres (only used when DB_DIALECT=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=leave_management
DB_USER=postgres
DB_PASSWORD=postgres

# --- Authentication (JWT) ---
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- Security ---
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- CORS ---
CLIENT_URL=http://localhost:5173

# --- Seed data (default password for all seeded users) ---
SEED_DEFAULT_PASSWORD=Password123!
